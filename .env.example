# Optional: skip Discord OAuth in local dev (mock user injected)
# DEV_AUTH_BYPASS=true

# Optional: use in-memory demo managers with fixture tunes instead of D1.
# No database needed. Writes persist only for the current Worker isolate.
# DEMO_MODE=true

# Only needed if testing real OAuth (not needed with DEV_AUTH_BYPASS)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
SESSION_SECRET=

# -----------------------------------------------------------------------------
# Maintainer only - NOT needed for contributors running `npm run dev`.
# Required to run `npm run images:migrate`, which uploads car images to
# Cloudflare R2. Credentials come from the R2 API token scoped to the
# forzatunes-images bucket.
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=forzatunes-images
R2_PUBLIC_BASE_URL=https://images.forzatunes.com
