---
import TuneHero from "./tune/TuneHero.astro";
import TuneActionCard from "./tune/TuneActionCard.astro";
import RelatedTunes from "./tune/RelatedTunes.astro";
import StarButton from "./tune/StarButton";
import type { TuneWithDetails, GameConfig } from "../lib/models";

interface Props {
  tune: TuneWithDetails;
  gameSlug: string;
  gameConfig: GameConfig;
  isStarred: boolean;
  isLoggedIn: boolean;
  isOwner?: boolean;
  moreByCreator?: TuneWithDetails[];
  similarTunes?: TuneWithDetails[];
  relatedStarredTuneIds?: Set<number>;
}

const {
  tune,
  gameSlug,
  gameConfig,
  isStarred,
  isLoggedIn,
  isOwner = false,
  moreByCreator = [],
  similarTunes = [],
  relatedStarredTuneIds = new Set<number>(),
} = Astro.props;

const tuneTypeLabel = gameConfig.tuneTypes.find(
  (t) => t.value === tune.tuneType,
)?.label ?? tune.tuneType;

const moreByCreatorWithSlug = moreByCreator.map((t) => ({
  ...t,
  gameSlug,
}));
const similarTunesWithSlug = similarTunes.map((t) => ({
  ...t,
  gameSlug,
}));

const gameConfigsBySlug = new Map<string, GameConfig>([
  [gameSlug, gameConfig],
]);
---

<article class="flex flex-col gap-4">
  <div class="flex items-center justify-between gap-3">
    <a
      href={`/${gameSlug}/tunes/`}
      class="inline-flex items-stretch text-sm font-heading font-bold uppercase tracking-widest border border-gray-700 divide-x divide-gray-700 text-gray-300 hover:border-accent-500 hover:text-accent-300 transition-colors overflow-hidden"
      aria-label="Back to tunes"
    >
      <span class="px-3 py-1.5 bg-gray-900 text-accent-400 flex items-center" aria-hidden="true">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </span>
      <span class="px-3 py-1.5 bg-gray-950/60 flex items-center">Back</span>
    </a>
    <StarButton
      client:load
      tuneId={tune.id}
      initialStarred={isStarred}
      initialCount={tune.starCount}
      isLoggedIn={isLoggedIn}
      variant="pill"
    />
  </div>

  <TuneHero
    tuneId={tune.id}
    title={tune.title}
    carMake={tune.carMake}
    carModel={tune.carModel}
    carYear={tune.carYear}
    carClass={tune.carClass}
    carImageUrl={tune.carImageUrl}
    piRating={tune.piRating}
    creatorGamertag={tune.creatorGamertag}
    tuneTypeLabel={tuneTypeLabel}
    drivetrain={tune.drivetrain}
    carCategory={tune.carCategory}
    trackName={tune.trackName}
    trackFieldLabel={gameConfig.trackFieldLabel}
    isLoggedIn={isLoggedIn}
    isOwner={isOwner}
  />

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 items-stretch">
    <div class="lg:col-span-2 flex flex-col gap-4 min-w-0">
      {tune.description && (
        <section class="flex-1 border border-gray-700 bg-gray-900 p-5">
          <h2 class="text-xs font-bold uppercase tracking-widest text-gray-500 mb-3">
            Description
          </h2>
          <p class="text-gray-200 leading-relaxed whitespace-pre-wrap">
            {tune.description}
          </p>
        </section>
      )}
    </div>

    <div class="lg:col-span-1">
      <TuneActionCard
        tuneId={tune.id}
        gameSlug={gameSlug}
        shareCode={tune.shareCode}
        isOwner={isOwner}
      />
    </div>
  </div>

  <RelatedTunes
    title={`More by ${tune.creatorGamertag}`}
    tunes={moreByCreatorWithSlug}
    starredTuneIds={relatedStarredTuneIds}
    isLoggedIn={isLoggedIn}
    gameConfigsBySlug={gameConfigsBySlug}
  />

  <RelatedTunes
    title="Similar tunes"
    subtitle={`Other ${tune.carClass}-class ${tuneTypeLabel.toLowerCase()} builds`}
    tunes={similarTunesWithSlug}
    starredTuneIds={relatedStarredTuneIds}
    isLoggedIn={isLoggedIn}
    gameConfigsBySlug={gameConfigsBySlug}
  />
</article>
