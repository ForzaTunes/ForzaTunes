---
import ShareCodeDisplay from "../ShareCodeDisplay.astro";

interface Props {
  tuneId: number;
  gameSlug: string;
  shareCode: string;
  isOwner: boolean;
}

const {
  tuneId,
  gameSlug,
  shareCode,
  isOwner,
} = Astro.props;
---

<aside class="lg:sticky lg:top-20">
  <div class="flex flex-col gap-4 border border-gray-700 bg-gray-900 p-5">
    <div>
      <p class="text-xs font-bold uppercase tracking-widest text-accent-400">
        Share code
      </p>
      <div class="mt-2">
        <ShareCodeDisplay code={shareCode} size="lg" />
      </div>
    </div>

    {isOwner && (
      <div class="flex items-center justify-end border-t border-gray-800 pt-4 text-xs">
        <a
          href={`/${gameSlug}/tunes/${tuneId}/edit`}
          class="text-accent-400 hover:text-accent-300 underline"
        >
          Edit this tune
        </a>
      </div>
    )}
  </div>
</aside>
