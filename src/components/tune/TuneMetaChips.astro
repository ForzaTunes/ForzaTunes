---
interface Props {
  tuneTypeLabel: string;
  drivetrain?: string | null;
  carCategory?: string | null;
  trackName?: string | null;
  trackFieldLabel?: string;
}

const {
  tuneTypeLabel,
  drivetrain,
  carCategory,
  trackName,
  trackFieldLabel = "Track",
} = Astro.props;

const trackLabelDisplay =
  trackFieldLabel.replace(/\s*\([^)]*\)\s*$/, "").trim() || "Track";
---

<div class="flex flex-wrap items-center gap-2">
  <span class="inline-flex items-center px-2 py-1 text-xs font-medium bg-emerald-900/50 text-emerald-300 border border-emerald-700">
    {tuneTypeLabel}
  </span>
  {drivetrain && (
    <span class="inline-flex items-center px-2 py-1 text-xs font-bold uppercase tracking-wider text-gray-200 border border-gray-600 bg-gray-950/70">
      {drivetrain}
    </span>
  )}
  {carCategory && (
    <span class="inline-flex items-center px-2 py-1 text-xs font-medium text-gray-300 border border-gray-700 bg-gray-900">
      {carCategory}
    </span>
  )}
  {trackName && (
    <span class="inline-flex items-center px-2 py-1 text-xs font-medium text-accent-300 border border-accent-700 bg-accent-900/40">
      <span class="mr-2 pr-2 border-r border-accent-700 text-[10px] uppercase tracking-widest text-accent-400">
        {trackLabelDisplay}
      </span>
      {trackName}
    </span>
  )}
</div>
