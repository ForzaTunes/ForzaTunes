---
import CarCard from "./CarCard.astro";
import type { Car } from "../../lib/models";

interface Props {
  cars: Car[];
  gameSlug: string;
}

const { cars, gameSlug } = Astro.props;
---

<div
  class="view-grid grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4"
  aria-label="Cars"
>
  {cars.map((car) => <CarCard car={car} gameSlug={gameSlug} />)}
</div>
