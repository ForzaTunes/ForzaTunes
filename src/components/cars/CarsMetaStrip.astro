---
interface Props {
  gameSlug: string;
  gameName: string;
  totalCount: number;
  filteredMake?: string;
}

const { gameSlug, gameName, totalCount, filteredMake } = Astro.props;

const countLabel = totalCount === 1 ? "Car" : "Cars";
---

<section
  aria-label="Cars catalog stats"
  class="flex items-center justify-between gap-4"
>
  <a
    href={`/${gameSlug}/`}
    class="inline-flex items-stretch text-sm font-heading font-bold uppercase tracking-widest border border-gray-700 divide-x divide-gray-700 text-gray-300 hover:border-accent-500 hover:text-accent-300 transition-colors overflow-hidden"
    aria-label={`Back to ${gameName}`}
  >
    <span
      class="px-3 py-1.5 bg-gray-900 text-accent-400 flex items-center"
      aria-hidden="true"
    >
      <svg
        class="w-4 h-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2.5"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </span>
    <span class="px-3 py-1.5 bg-gray-950/60 flex items-center">Back</span>
  </a>

  <div
    class="flex items-baseline gap-2 min-w-0 border border-gray-700 bg-gray-900 px-4 py-2"
  >
    <span
      id="car-count"
      class="text-base font-heading font-bold text-white tabular-nums"
    >
      {totalCount.toLocaleString()}
    </span>
    <span
      class="text-[11px] font-heading uppercase tracking-widest text-gray-400 truncate"
    >
      {filteredMake ? `${countLabel} by ${filteredMake}` : countLabel}
    </span>
  </div>
</section>
