---
import type { Car } from "../../lib/models";
import {
  CAR_IMAGE_ONERROR,
  CarImageUrlResolver,
} from "../../lib/utils/carImage";

interface Props {
  car: Car;
  gameSlug: string;
}

const { car, gameSlug } = Astro.props;

const tunesHref = `/${gameSlug}/tunes?car=${car.id}`;
const searchHaystack = `${car.make} ${car.model} ${car.year}`.toLowerCase();
const initial = (car.make[0] ?? "?").toUpperCase();

const resolvedCarImage = CarImageUrlResolver.forCar(car, "tile");
---

<a
  href={tunesHref}
  class="car-card group relative flex flex-col border border-gray-700 bg-gray-900 hover:border-accent-500 focus-visible:border-accent-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-400 transition-colors"
  data-car-id={car.id}
  data-make={car.make}
  data-search={searchHaystack}
  aria-label={`View tunes for ${car.year} ${car.make} ${car.model}`}
>
  <div class="relative aspect-[16/10] bg-gray-950 overflow-hidden">
    {resolvedCarImage ? (
      <img
        src={resolvedCarImage}
        alt=""
        aria-hidden="true"
        loading="lazy"
        onerror={CAR_IMAGE_ONERROR}
        class="absolute inset-0 w-full h-full object-cover select-none"
      />
    ) : (
      <div
        aria-hidden="true"
        class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-accent-900/40 via-gray-950 to-gray-950"
      >
        <span
          class="text-6xl font-heading font-extrabold italic uppercase tracking-widest text-accent-500/30 select-none"
        >
          {initial}
        </span>
      </div>
    )}
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 bg-gradient-to-t from-gray-950/80 via-transparent to-transparent"
    ></div>
  </div>

  <div class="flex-1 flex flex-col gap-1 p-3">
    <div class="flex items-baseline justify-between gap-2">
      <span
        class="text-[10px] font-heading uppercase tracking-widest text-gray-500 tabular-nums"
      >
        {car.year}
      </span>
      {car.category && (
        <span
          class="inline-flex items-center px-1.5 py-0.5 text-[10px] font-heading font-bold uppercase tracking-widest text-gray-300 border border-gray-700 bg-gray-950/70"
        >
          {car.category}
        </span>
      )}
    </div>
    <div
      class="text-[11px] font-heading font-bold uppercase tracking-widest text-accent-300 truncate"
    >
      {car.make}
    </div>
    <div
      class="text-sm font-medium text-white truncate group-hover:text-accent-200 transition-colors"
    >
      {car.model}
    </div>
  </div>
</a>
