---
import TuneListView from "../TuneListView.astro";
import ProfileHeader from "./ProfileHeader.astro";
import ProfileStats from "./ProfileStats.astro";
import ProfileFilterBar from "./ProfileFilterBar";
import type { GameConfig, TuneSortField, UserProfile } from "../../lib/models";
import type {
  ProfileGameOption,
  ProfileStats as ProfileStatsData,
  ProfileTuneItem,
  ProfileTab,
} from "../../lib/profile/ProfileDataLoader";

interface Props {
  profileUser: UserProfile;
  isOwner: boolean;
  ownerDiscordUsername?: string;
  stats: ProfileStatsData;
  tunes: ProfileTuneItem[];
  starredTuneIds: Set<number>;
  gameConfigsBySlug: Map<string, GameConfig>;
  availableGames: ProfileGameOption[];
  activeTab: ProfileTab;
  activeGameSlug: string | null;
  activeSort: TuneSortField;
  page: number;
  limit: number;
  baseUrl: string;
  viewerLoggedIn: boolean;
}

const {
  profileUser,
  isOwner,
  ownerDiscordUsername,
  stats,
  tunes,
  starredTuneIds,
  gameConfigsBySlug,
  availableGames,
  activeTab,
  activeGameSlug,
  activeSort,
  page,
  limit,
  baseUrl,
  viewerLoggedIn,
} = Astro.props;

function buildHref(overrides: {
  tab?: ProfileTab;
  page?: number;
}): string {
  const params = new URLSearchParams();
  const tab = overrides.tab ?? activeTab;
  if (tab === "starred") params.set("tab", "starred");
  if (activeGameSlug) params.set("game", activeGameSlug);
  if (activeSort !== "newest") params.set("sort", activeSort);
  const targetPage = overrides.page ?? 1;
  if (targetPage > 1) params.set("page", String(targetPage));
  const qs = params.toString();
  return qs ? `${baseUrl}?${qs}` : baseUrl;
}

const tabClasses = (isActive: boolean) =>
  `pb-2 px-1 text-sm font-heading uppercase tracking-widest border-b-2 transition-colors ${
    isActive
      ? "border-accent-500 text-accent-400"
      : "border-transparent text-gray-400 hover:text-gray-200"
  }`;

const filterSuffix = activeGameSlug
  ? ` for ${availableGames.find((g) => g.slug === activeGameSlug)?.name ?? activeGameSlug}`
  : "";

const displayName = profileUser.forzaGamertag ?? profileUser.username;

const emptyMessage = activeTab === "starred"
  ? (isOwner
      ? `You haven't starred any tunes${filterSuffix} yet.`
      : `${displayName} hasn't starred any tunes${filterSuffix} yet.`)
  : (isOwner
      ? `You haven't submitted any tunes${filterSuffix} yet.`
      : `${displayName} hasn't submitted any tunes${filterSuffix} yet.`);

const hasNextPage = tunes.length === limit;
---

<div class="max-w-6xl mx-auto px-4 py-8">
  <ProfileHeader
    profileUser={profileUser}
    isOwner={isOwner}
    ownerDiscordUsername={ownerDiscordUsername}
  />

  <ProfileStats
    tuneCount={stats.tuneCount}
    starsReceived={stats.starsReceived}
    memberSince={stats.memberSince}
  />

  <nav class="flex gap-4 border-b border-gray-700 mb-6">
    <a href={buildHref({ tab: "tunes" })} class={tabClasses(activeTab === "tunes")}>
      Tunes
    </a>
    <a href={buildHref({ tab: "starred" })} class={tabClasses(activeTab === "starred")}>
      Starred
    </a>
  </nav>

  <ProfileFilterBar
    client:load
    games={availableGames.map((g) => ({ slug: g.slug, name: g.name }))}
    currentGameSlug={activeGameSlug}
    currentSort={activeSort}
  />

  <TuneListView
    tunes={tunes}
    starredTuneIds={starredTuneIds}
    isLoggedIn={viewerLoggedIn}
    ownerActions={isOwner && activeTab === "tunes"}
    gameConfigsBySlug={gameConfigsBySlug}
    emptyMessage={emptyMessage}
  />

  {hasNextPage && (
    <div class="mt-8 flex justify-center">
      <a
        href={buildHref({ page: page + 1 })}
        class="px-4 py-2 bg-gray-800 border border-gray-700 hover:border-accent-500 text-sm font-heading uppercase tracking-widest text-gray-300 transition-colors"
      >
        Load more
      </a>
    </div>
  )}
</div>
