---
interface Props {
  currentSlug: string | null;
  games: Array<{ slug: string; name: string; shortName?: string }>;
}

const { currentSlug, games } = Astro.props;
---

<nav class="flex gap-1 sm:gap-1.5">
  {games.map((game) => {
    const isActive = game.slug === currentSlug;
    const classes = isActive
      ? "border-accent-500 bg-accent-600 text-white"
      : "border-gray-700 bg-gray-900 text-gray-300 hover:border-accent-500 hover:text-accent-300";
    return (
      <a
        href={`/${game.slug}/`}
        class={`px-2 sm:px-3 py-1 sm:py-1.5 text-[10px] sm:text-xs font-heading font-bold uppercase tracking-widest border transition-colors ${classes}`}
      >
        {game.shortName ?? game.name}
      </a>
    );
  })}
</nav>
