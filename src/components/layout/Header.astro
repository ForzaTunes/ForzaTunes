---
import GameNav from "../GameNav.astro";
import gamesJson from "../../data/games.json";

interface Props {
  currentGameSlug?: string;
  user?: {
    id: number;
    username: string;
    avatarUrl: string | null;
    forzaGamertag?: string | null;
  };
}

const { currentGameSlug, user } = Astro.props;

const NAV_ORDER = ["fh6", "fh5", "fm"];
const games = (gamesJson as Array<{ slug: string; name: string; shortName: string }>)
  .map((g) => ({ slug: g.slug, name: g.name, shortName: g.shortName }))
  .sort((a, b) => {
    const ai = NAV_ORDER.indexOf(a.slug);
    const bi = NAV_ORDER.indexOf(b.slug);
    return (ai === -1 ? Number.MAX_SAFE_INTEGER : ai) - (bi === -1 ? Number.MAX_SAFE_INTEGER : bi);
  });

const isRoot = Astro.url.pathname === "/";
const displayName = user ? (user.forzaGamertag ?? user.username) : "";
---

<header class="border-b border-gray-800 bg-gray-950/80 backdrop-blur-sm sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-3 sm:px-4 py-2.5 sm:py-3">
    <div class="flex items-center justify-between gap-2 sm:gap-3">
      <div class="flex items-center gap-2 sm:gap-4 min-w-0">
        <a href="/" class="text-base sm:text-xl font-heading font-bold italic uppercase tracking-widest text-white hover:text-accent-400 transition-colors shrink-0">
          FORZA<span class="text-accent-400">TUNES</span>
        </a>
        {!isRoot && (
          <GameNav currentSlug={currentGameSlug ?? null} games={games} />
        )}
      </div>
      <div class="flex items-center gap-2 sm:gap-3 shrink-0">
        {user ? (
          <div class="user-dropdown relative">
            <button
              type="button"
              class="inline-flex items-stretch h-7 sm:h-8 text-[10px] sm:text-xs font-heading font-bold uppercase tracking-widest border border-gray-700 divide-x divide-gray-700 bg-gray-900 text-gray-300 hover:border-accent-500 hover:text-accent-300 transition-colors"
            >
              <span class="px-3 flex items-center gap-2">
                <span>{displayName}</span>
                {user.id === 0 && (
                  <span class="text-[10px] font-heading uppercase tracking-wider text-yellow-400 border border-yellow-600 px-1 py-px leading-tight">Dev</span>
                )}
              </span>
              <span class="aspect-square h-full shrink-0 flex items-center justify-center bg-gray-950/60 overflow-hidden">
                {user.avatarUrl ? (
                  <img
                    src={user.avatarUrl}
                    alt={displayName}
                    class="w-full h-full object-cover"
                  />
                ) : (
                  <span class="w-full h-full flex items-center justify-center bg-gray-700 text-xs font-medium text-white">
                    {displayName.charAt(0).toUpperCase()}
                  </span>
                )}
              </span>
            </button>
            <div class="user-menu absolute right-0 mt-1 w-48 border border-gray-700 bg-gray-900 shadow-xl z-50 opacity-0 invisible transition-all duration-150">
              <a
                href="/profile"
                class="flex items-center gap-2 px-3 py-2.5 text-sm text-white hover:bg-accent-600 transition-colors"
              >
                <svg class="w-4 h-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                Profile
              </a>
              <div class="border-t border-gray-800" />
              <a
                href="/auth/logout"
                class="flex items-center gap-2 px-3 py-2.5 text-sm text-gray-400 hover:bg-gray-800 hover:text-white transition-colors"
              >
                <svg class="w-4 h-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                Log out
              </a>
            </div>
          </div>
        ) : (
          <div class="login-dropdown relative">
            <button
              type="button"
              class="inline-flex items-center gap-1.5 h-7 sm:h-8 bg-accent-600 px-2.5 sm:px-3 text-[10px] sm:text-xs font-heading font-bold uppercase tracking-widest text-white hover:bg-accent-500 transition-colors"
            >
              Login
              <svg class="w-3 h-3 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="square" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="login-menu absolute right-0 mt-1 w-56 border border-gray-700 bg-gray-900 shadow-xl z-50 opacity-0 invisible transition-all duration-150">
              <div class="px-3 py-2 border-b border-gray-800">
                <span class="text-xs font-heading uppercase tracking-wider text-gray-500">Sign in with</span>
              </div>
              <a
                href="/auth/login"
                class="flex items-center gap-3 px-3 py-2.5 text-sm text-white hover:bg-accent-600 transition-colors"
              >
                <svg class="w-5 h-5 text-[#5865F2]" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z" />
                </svg>
                Discord
              </a>
              <div
                class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-500 cursor-default"
                title="Coming soon"
              >
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M11.993 2L2 6.462v3.846h3.692v7.384H2V22h20v-4.308h-3.692v-7.384H22V6.462L11.993 2zM8.462 17.692v-7.384h2.769v7.384H8.462zm4.307 0v-7.384h2.77v7.384h-2.77z" />
                </svg>
                Xbox
                <span class="ml-auto text-[10px] font-heading uppercase tracking-wider text-gray-600 border border-gray-700 px-1.5 py-0.5">Soon</span>
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</header>

<style>
  .login-dropdown.open .login-menu,
  .user-dropdown.open .user-menu,
  .login-dropdown:focus-within .login-menu,
  .user-dropdown:focus-within .user-menu {
    opacity: 1;
    visibility: visible;
  }
</style>

<script>
  const DROPDOWN_SELECTORS = [".login-dropdown", ".user-dropdown"];

  function initDropdowns(): void {
    const dropdowns = document.querySelectorAll<HTMLElement>(
      DROPDOWN_SELECTORS.join(","),
    );

    dropdowns.forEach((dropdown) => {
      const trigger = dropdown.querySelector<HTMLButtonElement>("button");
      if (!trigger || trigger.dataset.dropdownBound === "1") return;
      trigger.dataset.dropdownBound = "1";

      trigger.addEventListener("click", (event) => {
        event.stopPropagation();
        const wasOpen = dropdown.classList.contains("open");
        document
          .querySelectorAll<HTMLElement>(".login-dropdown.open, .user-dropdown.open")
          .forEach((d) => d.classList.remove("open"));
        if (!wasOpen) dropdown.classList.add("open");
      });
    });
  }

  function bindGlobalDismissers(): void {
    if (document.documentElement.dataset.dropdownDismissers === "1") return;
    document.documentElement.dataset.dropdownDismissers = "1";

    document.addEventListener("click", (event) => {
      const target = event.target as Node | null;
      document
        .querySelectorAll<HTMLElement>(".login-dropdown.open, .user-dropdown.open")
        .forEach((dropdown) => {
          if (!target || !dropdown.contains(target)) {
            dropdown.classList.remove("open");
          }
        });
    });

    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      document
        .querySelectorAll<HTMLElement>(".login-dropdown.open, .user-dropdown.open")
        .forEach((d) => d.classList.remove("open"));
    });
  }

  initDropdowns();
  bindGlobalDismissers();
</script>
