---
import PageShell from "../layout/PageShell.astro";

interface Props {
  title?: string;
  message: string;
}

const { title = "Login failed", message } = Astro.props;
---

<PageShell
  title={`${title} — ForzaTunes`}
  description="Authentication error"
>
  <div class="max-w-xl mx-auto px-4 py-16 text-center">
    <h1 class="text-3xl font-heading font-bold text-white">{title}</h1>
    <p class="mt-4 text-gray-300">{message}</p>
    <div class="mt-8 flex justify-center gap-3">
      <a
        href="/auth/login"
        class="bg-accent-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-accent-500 transition-colors"
      >
        Try again
      </a>
      <a
        href="/"
        class="border border-gray-700 bg-gray-900 px-5 py-2.5 text-sm font-semibold text-gray-300 hover:bg-gray-800 transition-colors"
      >
        Back to home
      </a>
    </div>
  </div>
</PageShell>
