---
import TuneGrid from "../../TuneGrid.astro";
import type { GameConfig, TuneWithDetails } from "../../../lib/models";

interface Props {
  gameSlug: string;
  tunes: TuneWithDetails[];
  starredTuneIds: Set<number>;
  isLoggedIn: boolean;
  config: GameConfig;
}

const { gameSlug, tunes, starredTuneIds, isLoggedIn, config } = Astro.props;

const decoratedTunes = tunes.map((t) => ({ ...t, gameSlug }));
const tuneTypeLabels = new Map<string, string>(
  config.tuneTypes.map((t) => [t.value, t.label]),
);
---

{tunes.length > 0 && (
  <section aria-label="Latest tunes" class="space-y-3">
    <div class="flex items-baseline justify-between gap-3">
      <h2 class="text-xs font-heading uppercase tracking-widest text-gray-400">
        Latest Additions
      </h2>
      <a
        href={`/${gameSlug}/tunes/?sort=newest`}
        class="inline-flex items-center gap-1 text-[11px] font-heading uppercase tracking-widest text-accent-300 hover:text-accent-200 transition-colors"
      >
        See More
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
    <TuneGrid
      tunes={decoratedTunes}
      starredTuneIds={starredTuneIds}
      isLoggedIn={isLoggedIn}
      tuneTypeLabels={tuneTypeLabels}
    />
  </section>
)}
