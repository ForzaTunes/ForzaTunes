---
import type { Car } from "../../lib/models";

interface TuneTypeOption {
  value: string;
  label: string;
}

interface ClassRange {
  class: string;
  min: number;
  max: number;
}

interface Filters {
  tuneTypes?: string[];
  carClasses?: string[];
  makes?: string[];
  drivetrains?: string[];
  piMin?: number;
  piMax?: number;
  carId?: number;
}

interface Props {
  filters: Filters;
  tuneTypes: TuneTypeOption[];
  classRanges?: ClassRange[];
  filterCar?: Car | null;
  baseUrl: string;
  searchParams: URLSearchParams;
}

const {
  filters,
  tuneTypes,
  filterCar,
  baseUrl,
  searchParams,
} = Astro.props;

const FILTER_PARAM_KEYS = [
  "type",
  "class",
  "make",
  "drivetrain",
  "piMin",
  "piMax",
  "car",
] as const;

function buildUrl(mutate: (params: URLSearchParams) => void): string {
  const params = new URLSearchParams(searchParams);
  mutate(params);
  params.delete("page");
  const qs = params.toString();
  return qs ? `${baseUrl}?${qs}` : baseUrl;
}

function buildRemoveUrl(removedKeys: readonly string[]): string {
  return buildUrl((params) => {
    for (const key of removedKeys) params.delete(key);
  });
}

function buildRemoveListValueUrl(
  key: string,
  valuesNow: string[],
  value: string,
): string {
  return buildUrl((params) => {
    const remaining = valuesNow.filter((v) => v !== value);
    if (remaining.length > 0) params.set(key, remaining.join(","));
    else params.delete(key);
  });
}

function piRangeLabel(min?: number, max?: number): string {
  if (min === undefined && max === undefined) return "";
  if (min !== undefined && max !== undefined) return `PI ${min}–${max}`;
  if (min !== undefined) return `PI ≥ ${min}`;
  return `PI ≤ ${max}`;
}

interface ChipData {
  label: string;
  href: string;
  ariaLabel: string;
}

interface ChipGroup {
  label: string;
  chips: ChipData[];
}

const typeChips: ChipData[] = [];
for (const value of filters.tuneTypes ?? []) {
  const label = tuneTypes.find((t) => t.value === value)?.label ?? value;
  typeChips.push({
    label,
    href: buildRemoveListValueUrl("type", filters.tuneTypes ?? [], value),
    ariaLabel: `Remove type filter: ${label}`,
  });
}

const classChips: ChipData[] = [];
for (const value of filters.carClasses ?? []) {
  const label = `${value} Class`;
  classChips.push({
    label,
    href: buildRemoveListValueUrl("class", filters.carClasses ?? [], value),
    ariaLabel: `Remove class filter: ${label}`,
  });
}

const piLabel = piRangeLabel(filters.piMin, filters.piMax);
if (piLabel) {
  classChips.push({
    label: piLabel,
    href: buildRemoveUrl(["piMin", "piMax"]),
    ariaLabel: `Remove PI range filter: ${piLabel}`,
  });
}

const makeChips: ChipData[] = [];
for (const value of filters.makes ?? []) {
  makeChips.push({
    label: value,
    href: buildRemoveListValueUrl("make", filters.makes ?? [], value),
    ariaLabel: `Remove make filter: ${value}`,
  });
}

const drivetrainChips: ChipData[] = [];
for (const value of filters.drivetrains ?? []) {
  drivetrainChips.push({
    label: value,
    href: buildRemoveListValueUrl(
      "drivetrain",
      filters.drivetrains ?? [],
      value,
    ),
    ariaLabel: `Remove drivetrain filter: ${value}`,
  });
}

const carChips: ChipData[] = [];
if (filters.carId && filterCar) {
  const label = `${filterCar.year} ${filterCar.make} ${filterCar.model}`;
  carChips.push({
    label,
    href: buildRemoveUrl(["car"]),
    ariaLabel: `Remove car filter: ${label}`,
  });
}

const groups: ChipGroup[] = [
  { label: "Car", chips: carChips },
  { label: "Type", chips: typeChips },
  { label: "Class", chips: classChips },
  { label: "Make", chips: makeChips },
  { label: "Drivetrain", chips: drivetrainChips },
].filter((g) => g.chips.length > 0);

const hasChips = groups.length > 0;
const clearAllHref = buildRemoveUrl(FILTER_PARAM_KEYS);
---

{hasChips && (
  <div class="flex items-start gap-3 bg-gray-900 border border-t-0 border-gray-700 px-4 pt-3 pb-3">
    <div class="grid grid-cols-[max-content_1fr] gap-x-3 gap-y-2 items-center flex-1 min-w-0">
      {groups.map((group) => (
        <>
          <span class="text-[10px] font-heading font-bold uppercase tracking-widest text-gray-500">
            {group.label}
          </span>
          <div class="flex flex-wrap items-center gap-2">
            {group.chips.map((chip) => (
              <a
                href={chip.href}
                aria-label={chip.ariaLabel}
                class="inline-flex items-stretch text-xs font-heading font-bold uppercase tracking-widest border border-gray-700 divide-x divide-gray-700 text-gray-300 hover:border-accent-500 hover:text-accent-300 transition-colors overflow-hidden"
              >
                <span
                  class="px-2 py-1 bg-gray-900 text-accent-400 flex items-center"
                  aria-hidden="true"
                >
                  <svg
                    class="w-3 h-3"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M6 18L18 6M6 6l12 12"
                    />
                  </svg>
                </span>
                <span class="px-2 py-1 bg-gray-950/60 flex items-center">
                  {chip.label}
                </span>
              </a>
            ))}
          </div>
        </>
      ))}
    </div>
    <a
      href={clearAllHref}
      class="shrink-0 text-xs font-heading font-bold uppercase tracking-widest text-accent-400 hover:text-accent-300 underline underline-offset-4 px-1 py-1 transition-colors"
    >
      Clear all
    </a>
  </div>
)}
