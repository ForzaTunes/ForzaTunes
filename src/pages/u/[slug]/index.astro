---
import PageShell from "../../../components/layout/PageShell.astro";
import ProfileView from "../../../components/profile/ProfileView.astro";
import { ProfileDataLoader } from "../../../lib/profile/ProfileDataLoader";
import type { TuneSortField } from "../../../lib/models";

const raw = Astro.params.slug;
if (!raw) {
  return new Response(null, { status: 404 });
}

const users = Astro.locals.managers.users;

// Gamertag alias: `/u/@Somebody` → 301 to canonical slug. Requires a single
// unambiguous gamertag match so enumeration via aliases is useless.
if (raw.startsWith("@")) {
  const alias = raw.slice(1);
  if (alias.length === 0) {
    return new Response(null, { status: 404 });
  }
  const match = await users.findByGamertag(alias);
  if (!match) {
    return new Response(null, { status: 404 });
  }
  return Astro.redirect(`/u/${match.public_slug}`, 301);
}

// Pure-numeric slugs (old `/u/1`-style enumeration) are rejected early so
// that nothing on this surface hints at user counts.
if (/^\d+$/.test(raw)) {
  return new Response(null, { status: 404 });
}

// Opaque slug shape: base62, length 8–32. Keeps the validator forgiving of
// future length tweaks while still rejecting garbage.
if (!/^[A-Za-z0-9]{8,32}$/.test(raw)) {
  return new Response(null, { status: 404 });
}

const profileRow = await users.findByPublicSlug(raw);
if (!profileRow) {
  return new Response(null, { status: 404 });
}

const VALID_SORTS: readonly TuneSortField[] = [
  "newest",
  "most_starred",
  "pi_asc",
  "pi_desc",
];

const viewer = Astro.locals.user;
const url = new URL(Astro.request.url);
const activeTab = url.searchParams.get("tab") === "starred"
  ? "starred"
  : "tunes";
const page = Math.max(1, Number(url.searchParams.get("page")) || 1);
const limit = 12;

const gameSlug = url.searchParams.get("game") ?? null;
const sortParam = url.searchParams.get("sort") as TuneSortField | null;
const activeSort: TuneSortField =
  sortParam && VALID_SORTS.includes(sortParam) ? sortParam : "newest";

const loader = new ProfileDataLoader(Astro.locals.managers);
const data = await loader.load({
  profileUserId: profileRow.id,
  viewerId: viewer?.id ?? null,
  activeTab,
  page,
  limit,
  gameSlug,
  sort: activeSort,
});

if (!data.profileUser) {
  return new Response(null, { status: 404 });
}

const isOwner = viewer?.id === data.profileUser.id;
const displayName = data.profileUser.forzaGamertag ?? data.profileUser.username;
const baseUrl = `/u/${data.profileUser.publicSlug}`;

const activeGameSlug =
  gameSlug && data.availableGames.some((g) => g.slug === gameSlug)
    ? gameSlug
    : null;
---

<PageShell
  title={`${displayName} — ForzaTunes`}
  description={`Tunes shared by ${displayName} on ForzaTunes.`}
  ogImage={`/og/profile/${data.profileUser.publicSlug}.png`}
>
  <ProfileView
    profileUser={data.profileUser}
    isOwner={isOwner}
    ownerDiscordUsername={isOwner ? viewer?.username : undefined}
    stats={data.stats}
    tunes={data.tunes}
    starredTuneIds={data.starredTuneIds}
    gameConfigsBySlug={data.gameConfigsBySlug}
    availableGames={data.availableGames}
    activeTab={activeTab}
    activeGameSlug={activeGameSlug}
    activeSort={activeSort}
    page={page}
    limit={limit}
    baseUrl={baseUrl}
    viewerLoggedIn={!!viewer}
  />
</PageShell>
